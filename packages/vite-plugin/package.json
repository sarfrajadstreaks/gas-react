{
  "name": "gas-vite-plugin",
  "version": "0.1.0",
  "description": "Vite plugin that deploys React apps to Google Apps Script with automatic code splitting",
  "type": "module",
  "license": "MIT",
  "author": "Sarfraj Akhtar",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sarfrajakhtar/gas-react.git",
    "directory": "packages/vite-plugin"
  },
  "homepage": "https://github.com/sarfrajakhtar/gas-react/tree/main/packages/vite-plugin",
  "bugs": {
    "url": "https://github.com/sarfrajakhtar/gas-react/issues"
  },
  "keywords": [
    "vite",
    "vite-plugin",
    "google-apps-script",
    "gas",
    "react",
    "code-splitting",
    "clasp"
  ],
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "typesVersions": {
    "*": {
      ".": [
        "dist/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@vitejs/plugin-react": ">=4.0.0",
    "vite": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "@vitejs/plugin-react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}
