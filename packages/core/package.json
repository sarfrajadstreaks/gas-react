{
  "name": "@sarfrajadstreaks/gas-core",
  "version": "0.1.0",
  "description": "Client-server bridge and server utilities for Google Apps Script React apps",
  "type": "module",
  "license": "MIT",
  "author": "Sarfraj Akhtar",
  "repository": {
    "type": "git",
    "url": "https://github.com/sarfrajadstreaks/gas-react",
    "directory": "packages/core"
  },
  "keywords": [
    "google-apps-script",
    "gas",
    "react",
    "server-bridge",
    "datastore",
    "cache"
  ],
  "exports": {
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "client": ["dist/client/index.d.ts"],
      "server": ["dist/server/index.d.ts"]
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  }
}
