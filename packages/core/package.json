{
  "name": "gas-react-core",
  "version": "0.1.2",
  "description": "Client-server bridge and server utilities for Google Apps Script React apps",
  "type": "module",
  "license": "MIT",
  "author": "Sarfraj Akhtar",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sarfrajadstreaks/gas-react.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/sarfrajadstreaks/gas-react/tree/main/packages/core",
  "bugs": {
    "url": "https://github.com/sarfrajadstreaks/gas-react/issues"
  },
  "keywords": [
    "google-apps-script",
    "gas",
    "react",
    "server-bridge",
    "datastore",
    "cache"
  ],
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "exports": {
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "client": [
        "dist/client/index.d.ts"
      ],
      "server": [
        "dist/server/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "release": "npm run build && npm test && npm version patch && npm publish --access public && git push && git push --tags && gh release create gas-core@$(node -p \"require('./package.json').version\") --generate-notes --title \"gas-react-core v$(node -p \"require('./package.json').version\")\""
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}
